  "item": [
    {
      "name": "Create a new user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var rand=Math.random().toString(36).substring(2);\r",
              "\r",
              "var usermail=\"Tony\"+rand+\"@gmail.com\";\r",
              "var usrname=\"Tony\"+rand;\r",
              "\r",
              "pm.environment.set(\"email_env\", usermail);\r",
              "pm.environment.set(\"name_env\", usrname);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var ResponseBody = JSON.parse(responseBody);\r",
              "pm.environment.set(\"userid_env\",ResponseBody.id);\r",
              "\r",
              "//Validate ID is Generated\r",
              "pm.test(\"ID is Generated\",()=>{\r",
              "    pm.expect(ResponseBody.id).to.exist;\r",
              "});\r",
              "\r",
              "\r",
              "\r",
              "\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n \"name\": \"{{name_env}}\", \r\n \"gender\": \"male\", \r\n \"email\": \"{{email_env}}\", \r\n \"status\": \"inactive\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://gorest.co.in/public/v2/users",
          "protocol": "https",
          "host": [
            "gorest",
            "co",
            "in"
          ],
          "path": [
            "public",
            "v2",
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get user details",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//validating json fields in the response\r",
              "pm.test(\"value of json fields\", () =>{\r",
              "var jsonData=pm.response.json();\r",
              "    pm.expect(jsonData.id).to.eql(pm.environment.get(\"userid_env\"));\r",
              "    pm.expect(jsonData.name).to.eql(pm.environment.get(\"name_env\"));\r",
              "    pm.expect(jsonData.email).to.eql(pm.environment.get(\"email_env\"));\r",
              "});\r",
              "//validate responseTime\r",
              "pm.test(\"responseTime is less than 150ms\",()=>{\r",
              "    pm.expect(pm.response.responseTime).to.be.below(150);\r",
              "});\r",
              "//validate content type in header\r",
              "pm.test(\"Content is application/JSON\", ()=>{\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.eql(\"application/json; charset=utf-8\");\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
